{
    "api_base": {
        "description": "API 地址",
        "type": "string",
        "hint": "默认: https://api.lingyaai.cn",
        "default": "https://api.lingyaai.cn"
    },
    "api_key": {
        "description": "API Key",
        "type": "string",
        "hint": "在灵芽AI控制台获取",
        "obvious_hint": false,
        "default": ""
    },
    "model": {
        "description": "默认模型",
        "type": "string",
        "options": ["wan2.7-t2v", "wan2.7-i2v", "wan2.7-r2v", "wan2.7-videoedit"],
        "labels": ["文生视频", "图生视频", "参考生视频", "视频编辑"],
        "default": "wan2.7-t2v"
    },
    "resolution": {
        "description": "分辨率",
        "type": "string",
        "options": ["720P", "1080P"],
        "labels": ["720P", "1080P"],
        "default": "720P"
    },
    "duration": {
        "description": "视频时长(秒)",
        "type": "int",
        "hint": "t2v/i2v:2-15, r2v/videoedit:2-10",
        "default": 5
    },
    "max_concurrent": {
        "description": "最大并发生成数",
        "type": "int",
        "hint": "同时进行的视频生成任务数量",
        "default": 3
    },
    "poll_timeout": {
        "description": "轮询超时时间(秒)",
        "type": "int",
        "hint": "视频生成最长等待时间",
        "default": 300
    },
    "poll_interval": {
        "description": "轮询间隔时间(秒)",
        "type": "int",
        "hint": "每次查询生成状态的间隔",
        "default": 15
    }
}
